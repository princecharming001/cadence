# Cadence — environment template. Copy to .env.local and fill in real values.
# .env.local is gitignored and MUST stay that way: SUPABASE_SERVICE_KEY,
# X_API_SECRET / X_ACCESS_*, and ZERNIO_API_KEY are full-control credentials.
# For production, set these in the Vercel project env, NOT in git.

# ── Claude (content generation) ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
# service_role — bypasses RLS, full DB access. SERVER ONLY. Never expose/commit.
SUPABASE_SERVICE_KEY=<supabase-service-role-key>
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key>

# ── X / Twitter (OAuth1 app creds + OAuth2 PKCE client) ──────────────────────
X_API_KEY=<x-api-key>
X_API_SECRET=<x-api-secret>
X_ACCESS_TOKEN=<x-access-token>
X_ACCESS_SECRET=<x-access-secret>
X_OAUTH_CLIENT_ID=<x-oauth2-client-id>
X_OAUTH_REDIRECT_URI=http://localhost:3000/api/x/callback
# Enable X API reads (pay-per-use) so engagement rules can auto-discover posts.
X_READ_ENABLED=true

# ── App / cron ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=<random-long-secret>

# ── Apify (LinkedIn / trend harvest scraping) ────────────────────────────────
APIFY_TOKEN=apify_api_...
APIFY_LINKEDIN_ACTOR=harvestapi~linkedin-profile-posts

# ── Zernio (publishing to IG / TikTok / LinkedIn) ────────────────────────────
ZERNIO_API_KEY=<zernio-api-key>

# ── Higgsfield (Soul image gen + AI/UGC video) ───────────────────────────────
HIGGSFIELD_API_KEY=<higgsfield-key>
HIGGSFIELD_API_SECRET=<higgsfield-secret>
# Generated video on. Mirror in Vercel for production renders.
ENABLE_AI_VIDEO=1

# ── Pexels (stock B-roll for edits, cached) ──────────────────────────────────
PEXELS_API_KEY=<pexels-key>

# ── Stripe (paywall) — leave blank to run billing-not-configured ─────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
NEXT_PUBLIC_PRO_PRICE=17
